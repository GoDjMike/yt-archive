#!/usr/bin/env sh
set -eu

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

if command -v python3 >/dev/null 2>&1; then
  PYTHON=python3
elif command -v python >/dev/null 2>&1; then
  PYTHON=python
else
  echo "Error: python not found. Install Python and retry." >&2
  exit 1
fi

exec "$PYTHON" "$SCRIPT_DIR/yt-archive.py" "$@"
